# Example Environment Variables
# Copy this file to .env and add your actual API keys

# OpenAI API Key (Required for examples 1-5)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Specify which OpenAI model to use
# Default is gpt-4o-mini (cheaper and faster)
# Other options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Key (Required only for example 6)
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
